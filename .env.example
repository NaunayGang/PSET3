# OpsCenter shared environment template
# Copy this file to .env in local development and adjust values.

# Postgres (used by Docker Compose)
POSTGRES_DB=opscenter
POSTGRES_USER=opscenter
POSTGRES_PASSWORD=opscenter
DB_PORT=5432

# Backend
# Local development
DATABASE_URL=postgresql://opscenter:opscenter@localhost:5432/opscenter
# Docker Compose
# DATABASE_URL=postgresql://opscenter:opscenter@db:5432/opscenter
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
DEBUG=False
API_PORT=8000

# CORS
CORS_ALLOW_ORIGINS=http://localhost:8501,http://localhost:3000,http://localhost:8000
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=True

# Frontend
# Local development
API_BASE_URL=http://localhost:8000
# Docker Compose
# API_BASE_URL=http://api:8000
UI_PORT=8501

# Notification adapters (optional placeholders)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@opscenter.com
SMTP_PASSWORD=your-email-password
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
