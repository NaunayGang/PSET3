# Docker Compose environment template

# Postgres
POSTGRES_DB=opscenter
POSTGRES_USER=opscenter
POSTGRES_PASSWORD=opscenter
DB_PORT=5432

# Backend
DATABASE_URL=postgresql://opscenter:opscenter@db:5432/opscenter
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
DEBUG=False
API_PORT=8000

# Frontend
API_BASE_URL=http://api:8000
UI_PORT=8501

# Notifications (placeholders)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@opscenter.com
SMTP_PASSWORD=your-email-password
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL