# OpsCenter shared environment template
# Copy this file to .env in local development and adjust values.

# Backend
DATABASE_URL=postgresql://opscenter:opscenter@localhost:5432/opscenter
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
DEBUG=False

# CORS
CORS_ALLOW_ORIGINS=http://localhost:8501,http://localhost:3000,http://localhost:8000
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=True

# Frontend
API_BASE_URL=http://localhost:8000

# Notification adapters (optional placeholders)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@opscenter.com
SMTP_PASSWORD=your-email-password
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
